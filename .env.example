# ──────────────────────────────────────────────────────────────
# Payments App — variables de entorno
# Copiá este archivo a .env.local y completá los valores.
# NUNCA commitees .env.local (está en .gitignore).
# En Vercel: Settings → Environment Variables.
# ──────────────────────────────────────────────────────────────

# Supabase (base de datos PostgreSQL propia)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# MercadoPago (modo sandbox)
MP_ACCESS_TOKEN=            # Access token del vendedor de prueba (server-side)
NEXT_PUBLIC_MP_PUBLIC_KEY=  # Public key para el Payment Brick (client-side)


# Comunicación máquina-a-máquina entre servicios
SERVICE_TOKEN=              # Secreto compartido entre las 4 apps

# URLs de los servicios hermanos
NEXT_PUBLIC_APP_URL=        # URL pública de esta app (back_urls de MP, links de checkout)

# Clerk (autenticación)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=
# IMPORTANTE: para que el rol llegue en el JWT, en Clerk Dashboard →
# Sessions → Customize session token, agregá:
#   { "metadata": "{{user.public_metadata}}" }
# y seteá publicMetadata.role = "finance_admin" en tu usuario admin.
